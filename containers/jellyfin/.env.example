# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# Run as your host user so files on the media disk stay readable.
# Find yours with:  id -u  and  id -g
PUID=1000
PGID=1000

# Timezone
TZ=Europe/Amsterdam

# Host path where your media hard disk is mounted (via /etc/fstab).
# Mount the disk at /data on the host; it's bind-mounted to /data in the
# container too, so the same path works on the Pi AND inside Jellyfin.
MEDIA_PATH=/data

# --- Optional: used by scripts/ManageSubtitles.sh (the subtitle importer) ---
# Jellyfin API key so the script auto-scans the library after importing subs,
# instead of prompting for it. Create one: Dashboard -> Advanced -> API Keys -> +
# Leave blank (or omit) to be asked at the prompt instead.
JELLYFIN_API_KEY=
# Override only if your setup differs from the defaults:
# JELLYFIN_URL=http://localhost:8096
# JELLYFIN_SHOWS=/data/jellyfin/Shows
