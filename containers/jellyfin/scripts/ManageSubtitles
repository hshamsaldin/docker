#!/usr/bin/env python3
"""
ManageSubtitles - attach subtitle files to episode videos for Jellyfin.

Matches each subtitle (from a .zip or a folder) to its episode video by SxxExx
code and copies it beside the video as  <video-basename>.<lang>.<ext>  so
Jellyfin auto-detects it. Run on the host (where the media + Jellyfin live).

Simple (interactive) - previews, asks to confirm, then applies + archives + flattens:
    ManageSubtitles "Game of Thrones" /tmp/subs.zip

Explicit:
    ManageSubtitles "<show>" <subs> --apply [--archive] [--flatten] [--lang ara]
    ManageSubtitles "<show>" <subs> --dry-run
    ManageSubtitles "<show>" <subs> --apply --jellyfin-url URL --jellyfin-key KEY

<show> may be a full path or just a name resolved under
$JELLYFIN_SHOWS (default /data/jellyfin/Shows). <subs> may be a .zip or a folder.
"""
import argparse, os, re, shutil, sys, tempfile, zipfile, urllib.request

VIDEO_EXT = (".mkv", ".mp4", ".avi", ".m4v")
SUB_EXT   = (".srt", ".ass", ".ssa", ".vtt", ".sub")
CODE_RE   = re.compile(r'[Ss](\d{1,2})[ ._-]*[Ee](\d{1,2})')

def code(name):
    m = CODE_RE.search(name)
    return (int(m.group(1)), int(m.group(2))) if m else None

def find(root, exts):
    out = []
    for d, _, files in os.walk(root):
        for f in files:
            if f.lower().endswith(exts):
                out.append(os.path.join(d, f))
    return out

def flatten_doubles(root, apply):
    doubles = [d for d, _, _ in os.walk(root)
               if os.path.basename(d) == os.path.basename(os.path.dirname(d))]
    for inner in sorted(doubles, key=len, reverse=True):
        parent = os.path.dirname(inner)
        print("FLATTEN  %s  ->  %s" % (inner, parent))
        if apply:
            for e in os.listdir(inner):
                shutil.move(os.path.join(inner, e), os.path.join(parent, e))
            os.rmdir(inner)

def process(show, src_dir, lang, apply, archive):
    subs = {}
    for f in find(src_dir, SUB_EXT):
        c = code(os.path.basename(f))
        if c:
            subs.setdefault(c, []).append(f)
    matched = missing = 0
    for v in sorted(find(show, VIDEO_EXT)):
        c = code(os.path.basename(v))
        if not c:
            continue
        srcs = subs.get(c)
        if not srcs:
            print("NO SUB   S%02dE%02d  %s" % (c[0], c[1], os.path.basename(v))); missing += 1; continue
        for src in srcs:
            ext = os.path.splitext(src)[1].lower()
            dst = os.path.splitext(v)[0] + "." + lang + ext
            print("S%02dE%02d  %s  ->  %s" % (c[0], c[1], os.path.basename(src), os.path.basename(dst)))
            if apply:
                shutil.copy2(src, dst)
                if archive:
                    adir = os.path.join(show, "Subtitles", "Season %02d" % c[0])
                    os.makedirs(adir, exist_ok=True)
                    shutil.copy2(src, os.path.join(adir, os.path.basename(dst)))
            matched += 1
    print("\n%s  matched=%d  missing=%d" % ("APPLIED" if apply else "DRY-RUN", matched, missing))
    return matched

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("show", help="show folder, or a name under $JELLYFIN_SHOWS")
    ap.add_argument("subs_source", help="a .zip file or a folder of subtitle files")
    ap.add_argument("--lang", default="ara", help="language tag (default: ara)")
    ap.add_argument("--apply", action="store_true", help="write without prompting")
    ap.add_argument("--dry-run", action="store_true", help="preview only, never prompt")
    ap.add_argument("--archive", action="store_true", help="copy into SHOW/Subtitles/Season NN/")
    ap.add_argument("--flatten", action="store_true", help="flatten X/X doubled folders first")
    ap.add_argument("--jellyfin-url", help="e.g. http://localhost:8096")
    ap.add_argument("--jellyfin-key", help="Jellyfin API key (to trigger a scan)")
    a = ap.parse_args()

    show = a.show if os.path.isdir(a.show) else \
        os.path.join(os.environ.get("JELLYFIN_SHOWS", "/data/jellyfin/Shows"), a.show)
    if not os.path.isdir(show):
        sys.exit("show not found: " + show)

    tmp, src_dir = None, a.subs_source
    if os.path.isfile(a.subs_source) and a.subs_source.lower().endswith(".zip"):
        tmp = tempfile.mkdtemp(prefix="subs-")
        with zipfile.ZipFile(a.subs_source) as z:
            z.extractall(tmp)
        src_dir = tmp
    elif not os.path.isdir(a.subs_source):
        sys.exit("subs_source not found: " + a.subs_source)

    print("Show: %s\nSubs: %s\n----- preview -----" % (show, a.subs_source))

    do_apply, archive, flatten = a.apply, a.archive, a.flatten
    if not a.apply and not a.dry_run:
        process(show, src_dir, a.lang, apply=False, archive=False)   # preview
        try:
            ans = input("\nApply these (place + archive + flatten)? [y/N] ").strip().lower()
        except EOFError:
            ans = ""
        if ans in ("y", "yes"):
            do_apply = archive = flatten = True
        else:
            print("Aborted.")
            if tmp: shutil.rmtree(tmp, ignore_errors=True)
            return

    if flatten:
        flatten_doubles(show, do_apply)
    process(show, src_dir, a.lang, apply=do_apply, archive=archive)
    if tmp:
        shutil.rmtree(tmp, ignore_errors=True)

    if do_apply and a.jellyfin_url and a.jellyfin_key:
        url = a.jellyfin_url.rstrip("/") + "/Library/Refresh?api_key=" + a.jellyfin_key
        try:
            urllib.request.urlopen(urllib.request.Request(url, method="POST"), timeout=10)
            print("Triggered Jellyfin library scan.")
        except Exception as e:
            print("Jellyfin scan failed:", e)

if __name__ == "__main__":
    main()
