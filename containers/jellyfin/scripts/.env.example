# Copy to .env (next to ManageSubtitles.sh) and fill in. NEVER commit .env (gitignored).
# Everything here is optional - ManageSubtitles.sh works fine without this file.

# Jellyfin API key, so the script auto-triggers a library scan after import
# instead of prompting. Create one: Jellyfin Dashboard -> Advanced -> API Keys -> +
JELLYFIN_API_KEY=

# Override defaults only if your setup differs:
# JELLYFIN_URL=http://localhost:8096
# JELLYFIN_SHOWS=/data/jellyfin/Shows
