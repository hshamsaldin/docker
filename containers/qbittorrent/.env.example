# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# Run qBittorrent as your host user so downloaded files stay readable.
# Find yours with:  id -u  and  id -g
PUID=1000
PGID=1000

# Timezone
TZ=Europe/Amsterdam

# --- ProtonVPN (WireGuard) ------------------------------------------------
# In the Proton account portal: Downloads -> WireGuard configuration.
# Pick a P2P server, enable "Moderate NAT" (required for port forwarding),
# generate the config, then copy ONLY the PrivateKey value here.
WIREGUARD_PRIVATE_KEY=

# Exit country/countries gluetun should connect to (comma-separated names).
SERVER_COUNTRIES=Netherlands

# Port forwarding — Proton supports it and torrents need it for good peer
# connectivity. "on" requires a port-forward-capable (P2P) server above.
VPN_PORT_FORWARDING=on

# --- qBittorrent WebUI ----------------------------------------------------
# How the WebUI is published on the host. Default exposes it to the LAN on
# :8080. To keep it localhost-only (e.g. behind a reverse proxy) use:
#   WEBUI_BIND=127.0.0.1:8080
WEBUI_BIND=8080

# Your LAN subnet, so gluetun's firewall allows return traffic to local
# clients hitting the WebUI. Match your actual network (check `ip route`).
LAN_SUBNET=192.168.1.0/24

# --- Storage --------------------------------------------------------------
# Host path for downloads, bind-mounted to /downloads in the container.
# Set save paths inside qBittorrent under /downloads (e.g. /downloads/complete).
DOWNLOADS_PATH=/data/downloads
